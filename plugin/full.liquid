<style>
  .nook-full {
    width: 780px;
    height: 600px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    position: relative;
    overflow: hidden;
  }

  .nook-full__device-status {
    position: absolute;
    top: 9px;
    right: 11px;
    display: flex;
    align-items: center;
    gap: 9px;
    z-index: 2;
  }

  .nook-full__device-item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nook-full__wifi {
    width: 23px;
    height: 18px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
  }

  .nook-full__wifi-bar {
    display: block;
    width: 5px;
    border: 1.7px solid #000;
    background: #fff;
  }

  .nook-full__wifi-bar--1 {
    height: 6px;
  }

  .nook-full__wifi-bar--2 {
    height: 11px;
  }

  .nook-full__wifi-bar--3 {
    height: 16px;
  }

  .nook-full__wifi--1 .nook-full__wifi-bar--1,
  .nook-full__wifi--2 .nook-full__wifi-bar--1,
  .nook-full__wifi--2 .nook-full__wifi-bar--2,
  .nook-full__wifi--3 .nook-full__wifi-bar {
    background: #000;
  }

  .nook-full__battery {
    width: 24px;
    height: 12px;
    display: block;
  }

  .nook-full__battery svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nook-full * {
    box-sizing: border-box;
  }

  .nook-full__top {
    height: calc(39.6% - 50px);
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    border-bottom: 3px solid #000;
    overflow: hidden;
  }

  .nook-full__cell {
    height: 100%;
  }

  .nook-full__cell + .nook-full__cell {
    border-left: 3px solid #000;
  }

  .nook-temp {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 18px 12px;
  }

  .nook-temp__title,
  .nook-hero__text,
  .nook-metrics__label,
  .nook-day__label {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    letter-spacing: 0;
  }

  .nook-temp__title {
    margin-top: 0;
    font-size: 28px;
    line-height: 1;
    text-align: center;
    font-weight: 400;
  }

  .nook-temp__value {
    margin-top: 7px;
    font-size: 106px;
    line-height: 0.74;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .nook-temp__value sup {
    font-size: 0.62em;
    vertical-align: top;
  }

  .nook-temp__range {
    margin-top: auto;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6%;
    padding: 0 20px 10px;
    transform: translateY(2px);
  }

  .nook-temp__range-item {
    text-align: center;
    font-size: 22px;
    line-height: 1.02;
    font-weight: 700;
  }

  .nook-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 0 14px 16px;
  }

  .nook-hero img {
    width: 154px;
    height: 116px;
    object-fit: contain;
    margin-top: -6px;
  }

  .nook-hero__text {
    margin-top: 0;
    min-height: 1.05em;
    font-size: 24px;
    line-height: 1;
    font-weight: 400;
    text-align: center;
    white-space: nowrap;
  }

  .nook-metrics {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
    padding: 5px 22px 11px;
  }

  .nook-metrics__row {
    display: grid;
    grid-template-columns: 34% 66%;
    align-items: center;
    gap: 14px;
  }

  .nook-metrics__label {
    font-size: 24px;
    line-height: 1;
    text-align: right;
    font-weight: 400;
  }

  .nook-metrics__value {
    font-size: 56px;
    line-height: 0.8;
    font-weight: 800;
    letter-spacing: -0.01em;
    white-space: nowrap;
    text-align: left;
  }

  .nook-metrics__suffix {
    font-size: 0.42em;
    margin-left: 0.01em;
  }

  .nook-full__hours {
    height: calc(22.6% + 70px);
    border-bottom: 3px solid #000;
  }

  .nook-hourly-chart {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-rows: 20px minmax(0, 1fr) 22px 24px;
  }

  .nook-hourly-chart__title {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
    text-align: center;
    padding-top: 10px;
    padding-bottom: 0;
  }

  .nook-hourly-chart__canvas {
    position: relative;
    min-height: 0;
    padding: 0 15px;
  }

  .nook-hourly-chart__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nook-hourly-chart__grid-line {
    stroke: #000;
    stroke-width: 0.6;
    opacity: 0.24;
    shape-rendering: crispEdges;
  }

  .nook-hourly-chart__grid-line--vertical {
    opacity: 0.16;
  }

  .nook-hourly-chart__line {
    fill: none;
    stroke: #000;
    stroke-width: 2.1;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nook-hourly-chart__point {
    fill: #000;
  }

  .nook-hourly-chart__axis-label {
    fill: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-anchor: end;
  }

  .nook-hourly-chart__values {
    position: relative;
    height: 22px;
    padding: 0 15px 0 25px;
  }

  .nook-hourly-chart__value {
    position: absolute;
    top: 0;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 17px;
    font-weight: 700;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .nook-hourly-chart__hours {
    position: relative;
    height: 24px;
    padding: 0 15px 2px 25px;
  }

  .nook-hourly-chart__hour-label {
    position: absolute;
    top: 0;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
    transform: translateX(-50%);
    white-space: nowrap;
  }

  .nook-full__days {
    height: calc(37.8% - 20px);
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }

  .nook-day {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    justify-items: center;
    align-items: center;
    padding: calc(3.2% + 10px) 4.5% calc(1.6% + 10px);
  }

  .nook-day__temps {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 20px;
    line-height: 0.84;
    font-weight: 700;
  }

  .nook-day__precip {
    margin-top: 0;
    width: 100%;
    min-height: 0.96em;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-day img {
    width: 110.4%;
    max-height: 96%;
    object-fit: contain;
    align-self: center;
    margin-top: -7%;
  }

  .nook-day__label {
    margin-top: -18%;
    font-size: 18px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-day--muted {
    opacity: 0.35;
  }

  .nook-error {
    width: 780px;
    height: 600px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-align: center;
    padding: 48px;
    position: relative;
    overflow: hidden;
  }

  .nook-error__title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
  }

  .nook-error__copy {
    font-size: 22px;
    line-height: 1.2;
    max-width: 620px;
  }
</style>

{% if ok %}
  {% assign precip_chart_id = "precip-chart-" | append_random %}
  {% assign wifi_strength = trmnl.device.wifi_strength | default: 0 %}
  {% assign battery_percent = trmnl.device.percent_charged | default: 0 %}
  {% assign battery_level = 0 %}
  {% if battery_percent >= 75 %}
    {% assign battery_level = 4 %}
  {% elsif battery_percent >= 50 %}
    {% assign battery_level = 3 %}
  {% elsif battery_percent >= 25 %}
    {% assign battery_level = 2 %}
  {% elsif battery_percent > 0 %}
    {% assign battery_level = 1 %}
  {% endif %}
  <div class="nook-full">
    <div class="nook-full__device-status" aria-label="Estado del dispositivo">
      <div class="nook-full__device-item" aria-hidden="true">
        <div class="nook-full__wifi nook-full__wifi--{{ wifi_strength }}">
          <span class="nook-full__wifi-bar nook-full__wifi-bar--1"></span>
          <span class="nook-full__wifi-bar nook-full__wifi-bar--2"></span>
          <span class="nook-full__wifi-bar nook-full__wifi-bar--3"></span>
        </div>
      </div>
      <div class="nook-full__device-item" aria-hidden="true">
        <div class="nook-full__battery">
          {% if battery_level == 0 %}
            <svg viewBox="0 0 31 14" aria-hidden="true" focusable="false">
              <rect x="1" y="1" width="26" height="12" fill="none" stroke="#000" stroke-width="2"></rect>
              <rect x="28" y="4" width="3" height="6" fill="#000"></rect>
            </svg>
          {% elsif battery_level == 1 %}
            <svg viewBox="0 0 31 14" aria-hidden="true" focusable="false">
              <rect x="1" y="1" width="26" height="12" fill="none" stroke="#000" stroke-width="2"></rect>
              <rect x="4" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="28" y="4" width="3" height="6" fill="#000"></rect>
            </svg>
          {% elsif battery_level == 2 %}
            <svg viewBox="0 0 31 14" aria-hidden="true" focusable="false">
              <rect x="1" y="1" width="26" height="12" fill="none" stroke="#000" stroke-width="2"></rect>
              <rect x="4" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="11" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="28" y="4" width="3" height="6" fill="#000"></rect>
            </svg>
          {% elsif battery_level == 3 %}
            <svg viewBox="0 0 31 14" aria-hidden="true" focusable="false">
              <rect x="1" y="1" width="26" height="12" fill="none" stroke="#000" stroke-width="2"></rect>
              <rect x="4" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="10" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="16" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="28" y="4" width="3" height="6" fill="#000"></rect>
            </svg>
          {% else %}
            <svg viewBox="0 0 31 14" aria-hidden="true" focusable="false">
              <rect x="1" y="1" width="26" height="12" fill="none" stroke="#000" stroke-width="2"></rect>
              <rect x="3" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="8" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="13" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="18" y="3" width="3" height="8" fill="#000"></rect>
              <rect x="28" y="4" width="3" height="6" fill="#000"></rect>
            </svg>
          {% endif %}
        </div>
      </div>
    </div>
    <section class="nook-full__top">
      <div class="nook-full__cell nook-temp">
        <div class="nook-temp__title">Temperatura</div>
        <div class="nook-temp__value">{{ current.temperature }}<sup>°</sup></div>
        <div class="nook-temp__range">
          <div class="nook-temp__range-item">{{ current.min }}°</div>
          <div class="nook-temp__range-item">{{ current.max }}°</div>
        </div>
      </div>
      <div class="nook-full__cell nook-hero">
        <img src="{{ hero.icon_url }}" alt="{{ hero.condition_text | escape }}">
        <div class="nook-hero__text">{{ hero.condition_text_es | default: hero.condition_text }}</div>
      </div>
      <div class="nook-full__cell nook-metrics">
        <div class="nook-metrics__row">
          <div class="nook-metrics__label">Sensación<br>Térmica</div>
          <div class="nook-metrics__value">{{ current.feels_like }}°</div>
        </div>
        <div class="nook-metrics__row">
          <div class="nook-metrics__label">Humedad</div>
          <div class="nook-metrics__value">{{ current.humidity }}<span class="nook-metrics__suffix">%</span></div>
        </div>
        <div class="nook-metrics__row">
          <div class="nook-metrics__label">Presión</div>
          <div class="nook-metrics__value">{{ current.pressure_hpa }}<span class="nook-metrics__suffix">hPa</span></div>
        </div>
      </div>
    </section>

    <section class="nook-full__hours">
      <div
        class="nook-hourly-chart"
        id="{{ precip_chart_id }}"
        data-values="{% for hour in hours limit: 12 %}{{ hour.precipitation_chance | default: 0 }}{% unless forloop.last %},{% endunless %}{% endfor %}"
        data-times="{% for hour in hours limit: 12 %}{{ hour.time_label }}{% unless forloop.last %}|{% endunless %}{% endfor %}"
      >
        <div class="nook-hourly-chart__title">Pronóstico de precipitaciones</div>
        <div class="nook-hourly-chart__canvas"></div>
        <div class="nook-hourly-chart__values"></div>
        <div class="nook-hourly-chart__hours"></div>
      </div>
    </section>

    <section class="nook-full__days">
      {% for day in days limit: 7 %}
        <div class="nook-day{% unless day.available %} nook-day--muted{% endunless %}">
          <div class="nook-day__temps">
            <div>{{ day.min }}°</div>
            <div>{{ day.max }}°</div>
          </div>
          <div class="nook-day__precip">{{ day.precipitation_chance }}%</div>
          <img src="{{ day.icon_url }}" alt="{{ day.condition_text | escape }}">
          <div class="nook-day__label">{{ day.day_label }}</div>
        </div>
      {% endfor %}
    </section>
  </div>
  <script>
    (function () {
      const container = document.getElementById("{{ precip_chart_id }}");
      if (!container) return;

      const canvas = container.querySelector(".nook-hourly-chart__canvas");
      const valuesRow = container.querySelector(".nook-hourly-chart__values");
      const hoursRow = container.querySelector(".nook-hourly-chart__hours");
      if (!canvas || !valuesRow || !hoursRow) return;

      const values = (container.dataset.values || "")
        .split(",")
        .map((value) => Number(value.trim()))
        .filter((value) => !Number.isNaN(value));
      const times = (container.dataset.times || "").split("|");

      const width = canvas.clientWidth || 760;
      const height = canvas.clientHeight || 92;
      const leftPad = 28;
      const rightPad = 12;
      const plotTop = 10;
      const plotBottom = 10;
      const chartWidth = width - leftPad - rightPad;
      const chartHeight = height - plotTop - plotBottom;
      const safeValues = values.length > 0 ? values : Array.from({ length: 12 }, () => 0);

      const points = safeValues.map((value, index) => {
        const ratio = safeValues.length === 1 ? 0.5 : index / (safeValues.length - 1);
        const x = leftPad + chartWidth * ratio;
        const normalized = Math.max(0, Math.min(100, value)) / 100;
        const y = plotTop + chartHeight * (1 - normalized);
        return { x, y, value };
      });

      const rowOffset = valuesRow.getBoundingClientRect().left - canvas.getBoundingClientRect().left;
      const labelInset = 20;
      const labelTrackWidth = Math.max(0, chartWidth - labelInset * 2);
      const labelPoints = points.map((point, index) => {
        const ratio = safeValues.length === 1 ? 0.5 : index / (safeValues.length - 1);
        const x = leftPad + labelInset + labelTrackWidth * ratio - rowOffset;
        return {
          x,
          value: point.value,
          time: times[index] || "",
        };
      });

      function buildSmoothPath(series) {
        if (series.length === 0) return "";
        if (series.length === 1) return `M ${series[0].x} ${series[0].y}`;

        let path = `M ${series[0].x} ${series[0].y}`;

        for (let index = 0; index < series.length - 1; index += 1) {
          const current = series[index];
          const next = series[index + 1];
          const previous = series[index - 1] || current;
          const afterNext = series[index + 2] || next;

          const control1X = current.x + (next.x - previous.x) / 6;
          const control1Y = current.y + (next.y - previous.y) / 6;
          const control2X = next.x - (afterNext.x - current.x) / 6;
          const control2Y = next.y - (afterNext.y - current.y) / 6;

          path += ` C ${control1X} ${control1Y}, ${control2X} ${control2Y}, ${next.x} ${next.y}`;
        }

        return path;
      }

      const horizontalGrid = [0, 0.25, 0.5, 0.75, 1]
        .map((step) => {
          const y = plotTop + chartHeight * (1 - step);
          return `<line x1="${leftPad}" y1="${y}" x2="${width - rightPad}" y2="${y}" class="nook-hourly-chart__grid-line" />`;
        })
        .join("");

      const yAxisLabels = [100, 75, 50, 25, 0]
        .map((value, index) => {
          const step = index / 4;
          const y = plotTop + chartHeight * step + 3;
          return `<text x="${leftPad - 6}" y="${y}" class="nook-hourly-chart__axis-label">${value}</text>`;
        })
        .join("");

      const verticalGrid = points
        .map((point) => `<line x1="${point.x}" y1="${plotTop}" x2="${point.x}" y2="${height - plotBottom}" class="nook-hourly-chart__grid-line nook-hourly-chart__grid-line--vertical" />`)
        .join("");

      const markers = points
        .map((point) => `<circle cx="${point.x}" cy="${point.y}" r="2.6" class="nook-hourly-chart__point" />`)
        .join("");

      canvas.innerHTML = `
        <svg class="nook-hourly-chart__svg" viewBox="0 0 ${width} ${height}" aria-label="Curva de precipitaciones próximas 12 horas" role="img">
          ${horizontalGrid}
          ${verticalGrid}
          ${yAxisLabels}
          <path d="${buildSmoothPath(points)}" class="nook-hourly-chart__line"></path>
          ${markers}
        </svg>
      `;

      valuesRow.innerHTML = labelPoints
        .map((point) => `<div class="nook-hourly-chart__value" style="left:${point.x}px">${point.value}%</div>`)
        .join("");

      hoursRow.innerHTML = labelPoints
        .map((point) => `<div class="nook-hourly-chart__hour-label" style="left:${point.x}px">${point.time}</div>`)
        .join("");
    })();
  </script>
{% else %}
  <div class="nook-error">
    <div class="nook-error__title">Sin datos del tiempo</div>
    <div class="nook-error__copy">{{ error.message | default: "No se pudo cargar el clima." }}</div>
  </div>
{% endif %}
