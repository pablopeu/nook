<style>
  .nook-half-h {
    width: 800px;
    height: 240px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .nook-half-h * {
    box-sizing: border-box;
  }

  .nook-half-h__top {
    height: 58%;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr 1.7fr;
    border-bottom: 3px solid #000;
  }

  .nook-half-h__top > div + div {
    border-left: 3px solid #000;
  }

  .nook-half-h__temp {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px 16px 8px;
  }

  .nook-half-h__title,
  .nook-half-h__hero-text,
  .nook-half-h__metric-label,
  .nook-half-h__day-label {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .nook-half-h__title {
    font-size: 22px;
    line-height: 1;
    font-weight: 400;
  }

  .nook-half-h__value {
    font-size: 72px;
    line-height: 0.8;
    font-weight: 800;
  }

  .nook-half-h__range {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    text-align: center;
    font-size: 20px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-half-h__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6px 10px 8px;
  }

  .nook-half-h__hero img {
    width: 96px;
    height: 72px;
    object-fit: contain;
  }

  .nook-half-h__hero-text {
    font-size: 18px;
    line-height: 1;
    text-align: center;
    white-space: nowrap;
  }

  .nook-half-h__metrics {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    padding: 8px 16px;
  }

  .nook-half-h__metric {
    display: grid;
    grid-template-columns: 38% 62%;
    align-items: center;
    gap: 12px;
  }

  .nook-half-h__metric-label {
    font-size: 18px;
    line-height: 1;
    text-align: right;
    font-weight: 400;
  }

  .nook-half-h__metric-value {
    font-size: 42px;
    line-height: 0.88;
    font-weight: 800;
    white-space: nowrap;
  }

  .nook-half-h__suffix {
    font-size: 0.44em;
  }

  .nook-half-h__bottom {
    height: 42%;
    display: grid;
    grid-template-columns: 6fr 4fr;
  }

  .nook-half-h__hours,
  .nook-half-h__days {
    display: grid;
    align-items: center;
  }

  .nook-half-h__hours {
    grid-template-columns: repeat(6, 1fr);
    border-right: 3px solid #000;
  }

  .nook-half-h__days {
    grid-template-columns: repeat(4, 1fr);
  }

  .nook-half-h__hour,
  .nook-half-h__day {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4px 2px;
  }

  .nook-half-h__hour img,
  .nook-half-h__day img {
    object-fit: contain;
  }

  .nook-half-h__hour img {
    width: 88%;
    height: 54%;
  }

  .nook-half-h__hour-label,
  .nook-half-h__day-label {
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-half-h__day-stats {
    font-size: 14px;
    line-height: 0.95;
    font-weight: 700;
    text-align: center;
  }

  .nook-half-h__day-precip {
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-half-h__day img {
    width: 72%;
    height: 42%;
  }

  .nook-half-h__error {
    width: 800px;
    height: 240px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
    font-size: 24px;
    font-weight: 700;
  }
</style>

{% if ok %}
  <div class="nook-half-h">
    <section class="nook-half-h__top">
      <div class="nook-half-h__temp">
        <div class="nook-half-h__title">Temperatura</div>
        <div class="nook-half-h__value">{{ current.temperature }}°</div>
        <div class="nook-half-h__range">
          <div>{{ current.min }}°</div>
          <div>{{ current.max }}°</div>
        </div>
      </div>
      <div class="nook-half-h__hero">
        <img src="{{ hero.icon_url }}" alt="{{ hero.condition_text | escape }}">
        <div class="nook-half-h__hero-text">{{ hero.condition_text_es | default: hero.condition_text }}</div>
      </div>
      <div class="nook-half-h__metrics">
        <div class="nook-half-h__metric">
          <div class="nook-half-h__metric-label">Sensación</div>
          <div class="nook-half-h__metric-value">{{ current.feels_like }}°</div>
        </div>
        <div class="nook-half-h__metric">
          <div class="nook-half-h__metric-label">Humedad</div>
          <div class="nook-half-h__metric-value">{{ current.humidity }}<span class="nook-half-h__suffix">%</span></div>
        </div>
        <div class="nook-half-h__metric">
          <div class="nook-half-h__metric-label">Presión</div>
          <div class="nook-half-h__metric-value">{{ current.pressure_hpa }}<span class="nook-half-h__suffix">hPa</span></div>
        </div>
      </div>
    </section>
    <section class="nook-half-h__bottom">
      <div class="nook-half-h__hours">
        {% for hour in hours limit: 6 %}
          <div class="nook-half-h__hour">
            <img src="{{ hour.icon_url }}" alt="{{ hour.condition_text | escape }}">
            <div class="nook-half-h__hour-label">{{ hour.time_label }}</div>
          </div>
        {% endfor %}
      </div>
      <div class="nook-half-h__days">
        {% for day in days limit: 4 %}
          <div class="nook-half-h__day">
            <div class="nook-half-h__day-stats">{{ day.min }}°<br>{{ day.max }}°</div>
            <div class="nook-half-h__day-precip">{{ day.precipitation_chance }}%</div>
            <img src="{{ day.icon_url }}" alt="{{ day.condition_text | escape }}">
            <div class="nook-half-h__day-label">{{ day.day_label }}</div>
          </div>
        {% endfor %}
      </div>
    </section>
  </div>
{% else %}
  <div class="nook-half-h__error">{{ error.message | default: "No se pudo cargar el clima." }}</div>
{% endif %}
