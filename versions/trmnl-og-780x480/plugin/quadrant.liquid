<style>
  .nook-quad {
    width: 400px;
    height: 240px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .nook-quad * {
    box-sizing: border-box;
  }

  .nook-quad__left {
    border-right: 3px solid #000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 10px 10px;
    text-align: center;
  }

  .nook-quad__title,
  .nook-quad__hero-text,
  .nook-quad__metric-label {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .nook-quad__title {
    font-size: 22px;
    line-height: 1;
    font-weight: 400;
  }

  .nook-quad__value {
    font-size: 78px;
    line-height: 0.8;
    font-weight: 800;
  }

  .nook-quad__range {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    font-size: 22px;
    line-height: 1;
    font-weight: 700;
  }

  .nook-quad__right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    padding: 10px 12px;
  }

  .nook-quad__hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    margin-bottom: 4px;
  }

  .nook-quad__hero img {
    width: 88px;
    height: 64px;
    object-fit: contain;
  }

  .nook-quad__hero-text {
    font-size: 16px;
    line-height: 1;
    text-align: center;
  }

  .nook-quad__metric {
    display: grid;
    grid-template-columns: 48% 52%;
    align-items: center;
    gap: 8px;
  }

  .nook-quad__metric-label {
    font-size: 16px;
    line-height: 1;
    text-align: right;
    font-weight: 400;
  }

  .nook-quad__metric-value {
    font-size: 30px;
    line-height: 0.9;
    font-weight: 800;
    white-space: nowrap;
  }

  .nook-quad__suffix {
    font-size: 0.42em;
  }

  .nook-quad__error {
    width: 400px;
    height: 240px;
    border: 3px solid #000;
    box-sizing: border-box;
    background: #fff;
    color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
    font-size: 22px;
    font-weight: 700;
  }
</style>

{% if ok %}
  <div class="nook-quad">
    <section class="nook-quad__left">
      <div class="nook-quad__title">Temperatura</div>
      <div class="nook-quad__value">{{ current.temperature }}°</div>
      <div class="nook-quad__range">
        <div>{{ current.min }}°</div>
        <div>{{ current.max }}°</div>
      </div>
    </section>
    <section class="nook-quad__right">
      <div class="nook-quad__hero">
        <img src="{{ hero.icon_url }}" alt="{{ hero.condition_text | escape }}">
        <div class="nook-quad__hero-text">{{ hero.condition_text_es | default: hero.condition_text }}</div>
      </div>
      <div class="nook-quad__metric">
        <div class="nook-quad__metric-label">Sensación</div>
        <div class="nook-quad__metric-value">{{ current.feels_like }}°</div>
      </div>
      <div class="nook-quad__metric">
        <div class="nook-quad__metric-label">Humedad</div>
        <div class="nook-quad__metric-value">{{ current.humidity }}<span class="nook-quad__suffix">%</span></div>
      </div>
      <div class="nook-quad__metric">
        <div class="nook-quad__metric-label">Presión</div>
        <div class="nook-quad__metric-value">{{ current.pressure_hpa }}<span class="nook-quad__suffix">hPa</span></div>
      </div>
    </section>
  </div>
{% else %}
  <div class="nook-quad__error">{{ error.message | default: "No se pudo cargar el clima." }}</div>
{% endif %}
